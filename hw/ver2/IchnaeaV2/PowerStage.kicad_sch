	(text "SwitchFreq = R * 8.28kHz/kOhm - 163.5kHz\nR = 68.1k ~= 400kHz"
		(exclude_from_sim no)
		(at 108.458 230.124 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "13458ab1-5a29-428a-97db-a918289acf49")
	)
	(text "V5 bypass. Place close to pin."
		(exclude_from_sim no)
		(at 110.49 43.434 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "34adce98-b95e-4b53-a42d-af308ff5540e")
	)
	(text "Sets max avg inductor current to ~30A. \nTrimmed with the IDAC_SETCUR register."
		(exclude_from_sim no)
		(at 72.644 78.74 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "39b930a7-b236-4be1-9b6c-84f394561285")
	)
	(text "CCM=0, DCM=0: Burst Mode\nCCM=0, DCM=1: Discontinuous Conduction Mode\nCCM=1, DCM=0: Forced Continuous Conduction Mode\nCCM=1, DCM=1: Forced Continuous Conduction Mode"
		(exclude_from_sim no)
		(at 172.974 245.11 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "48792de8-2343-4e2d-8949-3495f3fad02c")
	)
	(text "Corresponds to 3/4 * V5, or \n40mV peak DCR Sense. With this\nproject's inductor, that's about\n25A per phase."
		(exclude_from_sim no)
		(at 117.856 117.856 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "48f3c52c-f7bc-49b8-aacb-5a4b6f06b140")
	)
